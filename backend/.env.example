# Server
PORT=3001

# Database: use PostgreSQL in production (Railway), SQLite locally
# DATABASE_URL=postgresql://...  # Railway internal (auto-set on Railway)
# DATABASE_PUBLIC_URL=postgresql://...  # For local dev → Railway Postgres (copy from Railway)
# DATABASE_PATH=./trading_sync.db  # SQLite path when no Postgres URL set

# App URL (for email links - verification, password reset)
APP_URL=http://localhost:3000

# OpenAI (for screenshot analysis)
OPENAI_API_KEY=your-openai-api-key

# Auth (change in production!)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Email (optional - without SMTP, reset/verify links appear on screen in dev)
# Gmail: enable 2FA, then create App Password at myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=Trading Sync <noreply@yourapp.com>

# Default user (run: node backend/scripts/seedDefaultUser.js)
DEFAULT_USER_EMAIL=default@tradingsync.local
DEFAULT_USER_PASSWORD=changeme123
