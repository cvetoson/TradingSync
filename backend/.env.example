# Server
PORT=3001

# Database: use PostgreSQL in production (Railway), SQLite locally
# DATABASE_URL=postgresql://...  # Railway internal (auto-set on Railway)
# DATABASE_PUBLIC_URL=postgresql://...  # For local dev → Railway Postgres (copy from Railway)
# DATABASE_PATH=./trading_sync.db  # SQLite path when no Postgres URL set

# App URL (for email links - verification, password reset)
APP_URL=http://localhost:5173

# OpenAI (for screenshot analysis)
OPENAI_API_KEY=your-openai-api-key

# OpenFIGI (optional): ISIN → ticker mapping fallback when Yahoo search misses. Works without a key;
# register at openfigi.com for a free API key → higher rate limits (OPENFIGI_API_KEY).
# OPENFIGI_API_KEY=

# Auth (change in production!)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Email (optional - without config, reset/verify links appear on screen)
# Option A: Resend (recommended for Railway - works reliably from cloud)
# Sign up at resend.com, create API key, verify domain. Free tier: 100 emails/day.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Trading Sync <onboarding@resend.dev>  # or your verified domain
# Option B: Gmail SMTP (often blocked from cloud servers)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=Trading Sync <noreply@yourapp.com>

# Default user (run: node backend/scripts/seedDefaultUser.js)
DEFAULT_USER_EMAIL=default@tradingsync.local
DEFAULT_USER_PASSWORD=changeme123
